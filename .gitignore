# external reference repos — fetched by scripts/fetch_reference.py, never committed
external/

# experiment outputs
runs/*
!runs/.gitkeep

# python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# notebooks
.ipynb_checkpoints/

# secrets / local env
.env

# claude code — 로컬 상태만 제외 (rules/·skills/·hooks/·settings.json은 공유 자산)
.claude/settings.local.json
.claude/*.lock
